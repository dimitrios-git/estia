# swaynag — wildcharm-themed warning/error dialogs (e.g. the $mod+Shift+e "exit sway?"
# confirm). Colours come from themes/wildcharm/palette.yml, given as bare RRGGBB (no '#').
#
# The global options below are the defaults for every dialog; the [warning]/[error]
# sections override just the accent bottom-border per message type (swaynag's two built-in
# types — the sway exit binding passes `-t warning`). swaynag auto-reads this file from
# ~/.config/swaynag/config, so the binding itself needs no flags. Keep annotations on their
# own lines (no trailing inline comments).

font=Lilex Nerd Font Mono 11
background=0a0a0a
border=1e1e1e
border-bottom=ce0056
border-bottom-size=2
text=e0e0e0
button-background=111111
button-text=e0e0e0
details-background=111111

# warning — the sway exit confirm (-t warning): yellow accent line
[warning]
border-bottom=ffaf00

# error — bright-red accent line
[error]
border-bottom=ff5f87
