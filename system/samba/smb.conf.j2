#
# Samba config for {{ system_hostname | default('hestia') }} — file exchange with the Windows laptop{% if enable_tailscale | default(false) | bool %} over Tailscale{% else %} on the LAN{% endif %}.

# Tracked in the dotfiles repo as system/samba/smb.conf.j2; this is a LAYER-(a)
# system config — RENDERED BY ANSIBLE (the `samba` role) and copied to
# /etc/samba/smb.conf (never symlinked). The host-specific LAN subnet comes from
# host_vars (samba_lan_subnet) — see bootstrap/host_vars/localhost.yml.example.
# Full deploy runbook: system/samba/README.md. Design: docs/file-sharing-design.md.
#
# SECURITY MODEL: smbd listens on all interfaces{% if enable_tailscale | default(false) | bool %} (Samba 4.22 can't bind the
# Tailscale tun){% endif %}, and access is confined at the SMB LAYER by hosts allow/deny —
# only loopback, the home LAN{% if enable_tailscale | default(false) | bool %}, and the Tailscale CGNAT range{% endif %} may authenticate;
# everything else is rejected before auth. The LAN is allowed deliberately (full
# gigabit at home{% if enable_tailscale | default(false) | bool %} vs the tunnel's ~575 Mbit{% endif %}). This file is the coarse,
# on-host enforcement{% if enable_tailscale | default(false) | bool %}; per-node restriction can live in the Tailscale ACL{% endif %}.
#

[global]
   # --- Access control: LAN{% if enable_tailscale | default(false) | bool %} + Tailscale{% endif %} ---
   # smbd listens on all interfaces. Access is confined at the SMB layer by hosts
   # allow/deny: only loopback, the local LAN{% if enable_tailscale | default(false) | bool %}, and the Tailscale CGNAT range{% endif %} may
   # authenticate — everything else is rejected before auth.
{% if enable_tailscale | default(false) | bool %}
   # The LAN is allowed deliberately: on the trusted home LAN, mapping the share by
   # LAN IP gives full gigabit, whereas Tailscale always WireGuard-encrypts (even on
   # a same-LAN path) and caps ~575 Mbit. Use the LAN IP when home, the Tailscale IP
   # when remote (two Windows drive mappings).
   hosts allow = 127.0.0.1 {{ samba_lan_subnet }} {{ samba_tailscale_cgnat }}
{% else %}
   hosts allow = 127.0.0.1 {{ samba_lan_subnet }}
{% endif %}
   hosts deny = 0.0.0.0/0

   # --- Protocol ---
   server min protocol = SMB3
   client min protocol = SMB2
{% if enable_tailscale | default(false) | bool %}
   # No SMB-level encryption directive: the transport already runs inside the
   # Tailscale/WireGuard tunnel, so SMB3 encryption would only add CPU cost.
{% else %}
   # No SMB-level encryption directive: access is LAN-only (hosts allow). Add
   # `smb encrypt = required` if you ever expose the share beyond a trusted LAN.
{% endif %}

   # --- No guests / anonymous ---
   server role = standalone server
   map to guest = never
   restrict anonymous = 2

   # --- Hygiene: SMB/445 only, no legacy NetBIOS browsing on the LAN ---
   workgroup = WORKGROUP
   server string = {{ system_hostname | default('hestia') }}
   disable netbios = yes
   smb ports = 445
   log file = /var/log/samba/log.%m
   max log size = 1000

[share]
   comment = {{ system_hostname | default('hestia') }} <-> windows file exchange ({% if enable_tailscale | default(false) | bool %}Tailscale + LAN{% else %}LAN only{% endif %})
   path = /srv/smbshare
   valid users = @smbshare
   read only = no
   browseable = yes
   # New files -> group-rw; new dirs -> group-rwx + setgid; all owned by the
   # smbshare group, so dimitrios (a member) can read/write them locally too.
   force group = smbshare
   create mask = 0660
   force create mode = 0660
   directory mask = 0770
   force directory mode = 2770
   inherit acls = yes
